# ============================================================================
#  Plataforma de Preinscripciones IEM — Configuración de entorno
#  Copia este archivo a config/.env (permisos 0600). El instalador web lo
#  genera automáticamente. NUNCA subas config/.env al repositorio.
# ============================================================================

# --- Aplicación ---
APP_NAME="IEM Preinscripciones"
APP_ENV=production            # production | development
APP_DEBUG=false
APP_URL=https://preinscripciones.example.com
APP_KEY=                      # clave aleatoria de 64 hex (se genera en la instalación)
APP_LOCALE=es                 # es | ca | en | pt
APP_TIMEZONE=Europe/Madrid
FORCE_HTTPS=true
MAX_UPLOAD_MB=50

# --- Base de datos (MySQL vía PDO) ---
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=preinscripciones
DB_USER=root
DB_PASS=
DB_PREFIX=
DB_CHARSET=utf8mb4

# --- SMTP (PHPMailer) ---
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_ENCRYPTION=tls          # tls | ssl | none
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="IEM Preinscripciones"

# --- Stripe ---
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Actualizaciones OTA (Git) ---
GIT_REMOTE=origin
GIT_BRANCH=main
GIT_TOKEN=                    # token solo si el repositorio es privado

# --- Datos de retención RGPD (días); 0 = sin límite ---
DATA_RETENTION_DAYS=0
